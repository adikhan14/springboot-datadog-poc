{
  "@timestamp": {
    "$resolver": "timestamp",
    "pattern": {
      "format": "yyyy-MM-dd'T'HH:mm:ss.SSS'Z'",
      "timeZone": "UTC"
    }
  },
  "level": {
    "$resolver": "level",
    "field": "name"
  },
  "logger": {
    "$resolver": "logger",
    "field": "name"
  },
  "thread": {
    "$resolver": "thread",
    "field": "name"
  },
  "message": {
    "$resolver": "message",
    "stringified": true
  },
  "dd.trace_id": {
    "$resolver": "mdc",
    "key": "dd.trace_id"
  },
  "dd.span_id": {
    "$resolver": "mdc",
    "key": "dd.span_id"
  },
  "requestId": {
    "$resolver": "mdc",
    "key": "requestId"
  },
  "error": {
    "$resolver": "exception",
    "field": "stackTrace",
    "stringified": true
  }
}

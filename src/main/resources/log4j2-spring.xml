<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>
        <Console name="JSON_CONSOLE" target="SYSTEM_OUT">
            <JsonTemplateLayout
                    eventTemplateUri="classpath:log4j2-json-template.json"
                    omitEmptyFields="true">
                <EventTemplateAdditionalField
                        key="app"
                        value="${spring:spring.application.name}"
                        format="STRING"/>
            </JsonTemplateLayout>
        </Console>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="JSON_CONSOLE"/>
        </Root>
    </Loggers>

</Configuration>
